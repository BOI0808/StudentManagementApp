<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".AdminCreateUserActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:text="Đăng xuất"
                android:textColor="#D32F2F"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Tạo Tài Khoản"
                android:textColor="#1976D2"
                android:textSize="24sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Họ và tên">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtFullName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Mã số nhân viên">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtStaffId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:text="Hệ thống tự động phát sinh"
                android:textStyle="italic" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:hint="Tên đăng nhập">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:passwordToggleEnabled="true"
                android:hint="Mật khẩu">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Email">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:hint="Số điện thoại">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="phone" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Phân quyền hệ thống:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="12dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="1"
            android:rowCount="12">

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbTiepNhanHS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tiếp nhận học sinh (1)" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbLapDanhSachLop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lập danh sách lớp (2)" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbLapDanhSachHSChoLop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lập danh sách học sinh cho lớp (3)" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbLapDanhSachNamHoc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lập danh sách Năm học (4)" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbLapDanhSachKhoiLop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lập danh sách Khối lớp (5)" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbLapDanhSachMonHoc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lập danh sách Môn học (6)" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbTraCuuHS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tra cứu học sinh (7)" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbNhapDiem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nhập bảng điểm (8)" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbLoaiKiemTra"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nhập danh sách loại kiểm tra (9)" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbBaoCaoMon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lập báo cáo tổng kết môn (10)" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbBaoCaoHocKy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lập báo cáo tổng kết học kỳ (11)" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbCaiDatThamSo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cài đặt tham số hệ thống (12)" />

        </GridLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnXemDanhSach"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="8dp"
            android:text="XEM DANH SÁCH TÀI KHOẢN"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            app:strokeColor="#1976D2"
            android:textColor="#1976D2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateAccount"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="24dp"
            android:text="TẠO TÀI KHOẢN"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="8dp" />

    </LinearLayout>
</ScrollView>