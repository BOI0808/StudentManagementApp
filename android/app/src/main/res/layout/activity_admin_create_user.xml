<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true"
    tools:context=".AdminCreateUserActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:text="Đăng xuất"
                android:textColor="#D32F2F"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Tạo Tài Khoản"
                android:textColor="#1976D2"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnImportExcel"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_upload"
                app:tint="#388E3C"
                android:contentDescription="Import từ Excel" />
        </RelativeLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/loadingIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:indeterminate="true"
            android:visibility="gone"
            app:indicatorColor="#1976D2"
            app:trackColor="#E3F2FD" />

        <!-- Nhóm 1: Thông tin cá nhân -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Thông tin cá nhân"
                    android:textColor="#1976D2"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Họ và tên">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtFullName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Email">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Số điện thoại">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Nhóm 2: Tài khoản hệ thống -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Tài khoản hệ thống"
                    android:textColor="#1976D2"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Tên đăng nhập">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtUsername"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:passwordToggleEnabled="true"
                    android:hint="Mật khẩu">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Nhóm 3: Phân quyền -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Phân quyền hệ thống"
                    android:textColor="#1976D2"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnQuickAdmin"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:paddingHorizontal="12dp"
                            android:text="Admin"
                            android:textAllCaps="false"
                            android:textSize="12sp"
                            app:strokeColor="#1976D2" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnQuickTeacher"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:paddingHorizontal="12dp"
                            android:text="Giáo viên"
                            android:textAllCaps="false"
                            android:textSize="12sp"
                            app:strokeColor="#1976D2" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnQuickManagement"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:paddingHorizontal="12dp"
                            android:text="Ban giám hiệu"
                            android:textAllCaps="false"
                            android:textSize="12sp"
                            app:strokeColor="#1976D2" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnQuickClear"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="12dp"
                            android:text="Bỏ chọn tất cả"
                            android:textAllCaps="false"
                            android:textSize="12sp"
                            app:strokeColor="#D32F2F"
                            android:textColor="#D32F2F" />
                    </LinearLayout>
                </HorizontalScrollView>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="1">

                    <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/cbTiepNhanHS" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tiếp nhận học sinh (1)" />
                    <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/cbLapDanhSachLop" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lập danh sách lớp (2)" />
                    <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/cbLapDanhSachHSChoLop" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lập danh sách học sinh cho lớp (3)" />
                    <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/cbLapDanhSachNamHoc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lập danh sách Năm học (4)" />
                    <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/cbLapDanhSachKhoiLop" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lập danh sách Khối lớp (5)" />
                    <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/cbLapDanhSachMonHoc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lập danh sách Môn học (6)" />
                    <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/cbTraCuuHS" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tra cứu học sinh (7)" />
                    <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/cbNhapDiem" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nhập bảng điểm (8)" />
                    <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/cbLoaiKiemTra" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nhập danh sách loại kiểm tra (9)" />
                    <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/cbBaoCaoMon" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lập báo cáo tổng kết môn (10)" />
                    <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/cbBaoCaoHocKy" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lập báo cáo tổng kết học kỳ (11)" />
                    <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/cbCaiDatThamSo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cài đặt tham số hệ thống (12)" />
                </GridLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnXemDanhSach"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="8dp"
            android:text="XEM DANH SÁCH TÀI KHOẢN"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            app:strokeColor="#1976D2"
            android:textColor="#1976D2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateAccount"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="24dp"
            android:text="TẠO TÀI KHOẢN"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="8dp" />

    </LinearLayout>
</ScrollView>
